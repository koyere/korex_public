# ═══════════════════════════════════════════════════════════════
# KOREX - Configuración de Entorno
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# DISCORD
# ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_DEV_GUILD_ID=              # Guild para desarrollo (comandos instantáneos)

# ─────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────
DATABASE_PROVIDER=postgresql       # postgresql | mongodb | mysql | sqlite
DATABASE_URL=postgresql://user:password@localhost:5432/korex

# ─────────────────────────────────────────────────────────────────
# REDIS (Caché y Sessions)
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_PREFIX=korex:

# ─────────────────────────────────────────────────────────────────
# LAVALINK (Música)
# ─────────────────────────────────────────────────────────────────
MUSIC_ENABLED=true
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
LAVALINK_IDENTIFIER=main-node
LAVALINK_RESUME_KEY=
LAVALINK_RESUME_TIMEOUT=60000
LAVALINK_AUTO_RESUME=true
LAVALINK_USE_VERSION_PATH=true

# APIs de Música
YOUTUBE_API_ENABLED=true
YOUTUBE_API_KEY=
SPOTIFY_API_ENABLED=true
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SOUNDCLOUD_API_ENABLED=true
SOUNDCLOUD_CLIENT_ID=

# Configuración de Música
MUSIC_DEFAULT_VOLUME=50
MUSIC_MAX_QUEUE_SIZE=500
MUSIC_MAX_SONG_DURATION=3600
MUSIC_SEARCH_LIMIT=10
MUSIC_LEAVE_ON_EMPTY=true
MUSIC_LEAVE_ON_EMPTY_DELAY=300000
MUSIC_LEAVE_ON_END=true
MUSIC_LEAVE_ON_END_DELAY=30000

# ─────────────────────────────────────────────────────────────────
# API / PANEL WEB
# ─────────────────────────────────────────────────────────────────
API_PORT=3000
API_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173
JWT_SECRET=                        # Generar con: openssl rand -hex 64
JWT_EXPIRES_IN=7d
SESSION_SECRET=                    # Generar con: openssl rand -hex 32
CORS_ORIGINS=http://localhost:5173,https://panel.korex.dev

# Webhooks
GITHUB_WEBHOOK_SECRET=
WEBHOOK_TOKEN=                     # Para webhooks personalizados
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────
# LICENCIAMIENTO
# ─────────────────────────────────────────────────────────────────
LICENSE_KEY=
LICENSE_SERVER_URL=https://license.korex.dev/api
INSTALLATION_TOKEN=                # Auto-generado en primer inicio

# ─────────────────────────────────────────────────────────────────
# ADDONS (Claves de licencia individuales)
# ─────────────────────────────────────────────────────────────────
ADDON_STORE_LICENSE=
ADDON_STAFF_LICENSE=
ADDON_TICKETS_LICENSE=
ADDON_FORMS_LICENSE=
ADDON_LINKS_LICENSE=
ADDON_PASTE_LICENSE=
ADDON_MUSIC_PRO_LICENSE=
ADDON_ANALYTICS_PRO_LICENSE=
ADDON_IA_ASSISTANT_LICENSE=

# PayPal — Plan IDs por addon (crear en PayPal Dashboard > Products & Plans)
PAYPAL_PLAN_TICKETS=
PAYPAL_PLAN_STAFF=
PAYPAL_PLAN_FORMS=
PAYPAL_PLAN_STORE=
PAYPAL_PLAN_LINKS=
PAYPAL_PLAN_PASTE=
PAYPAL_PLAN_MUSIC_PRO=
PAYPAL_PLAN_ANALYTICS_PRO=
PAYPAL_PLAN_AI_ASSISTANT=

# ─────────────────────────────────────────────────────────────────
# INTEGRACIONES EXTERNAS
# ─────────────────────────────────────────────────────────────────
# Pagos (Addon Store)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# IA (Addon IA Assistant)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Otros
LASTFM_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────
# CONFIGURACIÓN GENERAL
# ─────────────────────────────────────────────────────────────────
NODE_ENV=development               # development | production | test
LOG_LEVEL=info                     # debug | info | warn | error
DEFAULT_PREFIX=!
DEFAULT_LANGUAGE=es
TIMEZONE=America/Mexico_City

# ─────────────────────────────────────────────────────────────────
# SEGURIDAD
# ─────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=                    # Generar con: openssl rand -hex 32
ERROR_CHANNEL_ID=                  # Canal para reportar errores críticos
# ─────────────────────────────────────────────────────────────────
# ADMIN PANEL — AUTENTICACIÓN
# Generar ADMIN_JWT_SECRET con: openssl rand -hex 64
# Generar CSRF_SECRET con: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=                  # Secreto JWT exclusivo para operadores admin
CSRF_SECRET=                       # Secreto para protección CSRF del panel admin
ADMIN_PANEL_URL=https://admin.korex.dev
ADMIN_RP_ID=admin.korex.dev        # Relying Party ID para WebAuthn (dominio sin protocolo)
ADMIN_RP_NAME=Korex Admin          # Nombre del Relying Party para WebAuthn

# ─────────────────────────────────────────────────────────────────
# ADMIN PANEL — EMAIL (Resend)
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...              # API key de Resend (resend.com)
RESEND_FROM_EMAIL=noreply@korex.dev

# ─────────────────────────────────────────────────────────────────
# ADMIN PANEL — NOTIFICACIONES AL EQUIPO
# ─────────────────────────────────────────────────────────────────
TEAM_DISCORD_WEBHOOK=              # Webhook de Discord para notificaciones al equipo
                                   # Ejemplo: https://discord.com/api/webhooks/...

# ─────────────────────────────────────────────────────────────────
# PANEL WEB (korex-web)
# ─────────────────────────────────────────────────────────────────
PANEL_URL=https://panel.korex.dev  # URL del dashboard de usuarios

