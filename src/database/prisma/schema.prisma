// ─── Store with Payments ──────────────────────────────────────────────────────

model StoreConfig {
  id      String @id @default(cuid())
  guildId String @unique

  // PayPal (v1)
  paypalMode                  String  @default("sandbox")
  paypalClientId              String?
  paypalClientSecretEncrypted String?
  paypalWebhookId             String?
  paypalWebhookUrl            String?

  // Store metadata
  enabled          Boolean @default(false)
  setupCompleted   Boolean @default(false)
  storeName        String  @default("")
  storeDescription String  @default("")
  currency         String  @default("USD")
  taxRate          Float   @default(0)

  // Catalog (JSON arrays managed from dashboard)
  products   Json @default("[]")
  categories Json @default("[]")
  coupons    Json @default("[]")

  // Channels
  salesChannelId String?
  logsChannelId  String?

  // Custom messages (null = use i18n defaults)
  purchaseEmbedMsg    String?
  refundEmbedMsg      String?
  digitalRevealNote   String?

  // Polling fallback
  pollingEnabled    Boolean  @default(true)
  pollingIntervalSec Int     @default(60)
  pollingStartSec   Int     @default(120)
  lastPolledAt      DateTime?

  // Refund policy
  autoRevoke     Boolean @default(true)
  logUnrevokable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild        Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  transactions StoreTransaction[]
  webhookLogs  StoreWebhookLog[]

  @@map("store_configs")
}

model StoreTransaction {
  id        String @id @default(cuid())
  guildId   String
  userId    String
  orderId   String
  productId String

  status   String @default("PENDING")
  amount   Float
  currency String

  // Delivery tracking
  deliveryType   String?
  roleId         String?
  channelIds     String[] @default([])
  digitalType    String?
  digitalClaimed Boolean  @default(false)
  digitalClaimedAt DateTime?

  // PayPal details
  paypalStatus String?
  captureId    String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  config StoreConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, orderId])
  @@index([guildId, userId])
  @@index([guildId, status])
  @@index([createdAt])
  @@map("store_transactions")
}

model StoreWebhookLog {
  id        String  @id @default(cuid())
  guildId   String
  eventType String
  paypalId  String?
  payload   Json
  processed Boolean @default(false)
  error     String?

  createdAt DateTime @default(now())

  config StoreConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, processed])
  @@index([guildId, createdAt])
  @@map("store_webhook_logs")
}

