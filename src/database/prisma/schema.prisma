  @@map("marketing_campaigns")
}

// ═══════════════════════════════════════════════════════════════
// ADMIN PANEL — LOG DE EMAILS
// ═══════════════════════════════════════════════════════════════

model EmailLog {
  id         String    @id @default(uuid())
  guildId    String?
  recipient  String
  templateId String
  campaignId String?
  status     String    @default("sent")      // sent | failed | opened
  resendId   String?
  error      String?
  sentAt     DateTime  @default(now())

  @@index([guildId])
  @@map("email_log")
}

// ═══════════════════════════════════════════════════════════════
// ADMIN PANEL — PREFERENCIAS DE NOTIFICACIÓN DEL GUILD
// ═══════════════════════════════════════════════════════════════

model GuildNotificationPref {
  guildId      String    @id
  supportEmail Boolean   @default(true)
  supportDm    Boolean   @default(false)
  supportBadge Boolean   @default(true)
  updatedAt    DateTime  @updatedAt

  @@map("guild_notification_prefs")
}

// ═══════════════════════════════════════════════════════════════
// ADDON: FORMS — Formularios Avanzados
// ═══════════════════════════════════════════════════════════════

enum FormStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum FormSubmissionStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

model FormConfig {
  id              String  @id @default(cuid())
  guildId         String  @unique
  reviewChannelId String?
  logChannelId    String?

  guild           Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  forms           Form[]
  panels          FormPanel[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("form_configs")
}

model Form {
  id               String     @id @default(cuid())
  configId         String
  guildId          String
  name             String
  description      String?
  emoji            String?
  status           FormStatus @default(ACTIVE)
  reviewChannelId  String?
  reviewerRoles    String[]   @default([])
  allowMultiple    Boolean    @default(false)
  cooldownHours    Int        @default(24)
  maxSubmissions   Int?
  approvalActions  Json       @default("[]")
  rejectionActions Json       @default("[]")
  dmOnSubmit       Boolean    @default(true)
  dmOnReview       Boolean    @default(true)
  order            Int        @default(0)

  config           FormConfig      @relation(fields: [configId], references: [id], onDelete: Cascade)
  fields           FormField[]
  submissions      FormSubmission[]
  panelForms       FormPanelForm[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([configId])
  @@map("forms")
}

model FormField {
  id          String  @id @default(cuid())
  formId      String
  order       Int     @default(0)
  type        String  @default("short")
  label       String
  placeholder String?
  required    Boolean @default(true)
  minLength   Int?
  maxLength   Int?

  form        Form    @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("form_fields")
}

model FormPanel {
  id           String  @id @default(cuid())
  configId     String
  guildId      String
  channelId    String
  messageId    String
  title        String
  description  String  @db.Text
  color        String  @default("#5865F2")
  footerText   String?
  imageUrl     String?
  thumbnailUrl String?
  panelType    String  @default("buttons")

  config       FormConfig      @relation(fields: [configId], references: [id], onDelete: Cascade)
  forms        FormPanelForm[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("form_panels")
}

model FormPanelForm {
  panelId  String
  formId   String
  order    Int    @default(0)

  panel    FormPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  form     Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@id([panelId, formId])
  @@map("form_panel_forms")
}

model FormSubmission {
  id              String               @id @default(cuid())
  formId          String
  guildId         String
  userId          String
  status          FormSubmissionStatus @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNote      String?
  reviewMessageId String?
  reviewChannelId String?

  form            Form                   @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers         FormSubmissionAnswer[]

  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([formId])
  @@index([guildId, userId])
  @@index([status])
  @@map("form_submissions")
}

model FormSubmissionAnswer {
  id           String  @id @default(cuid())
  submissionId String
  fieldId      String
  fieldLabel   String
  answer       String  @db.Text

  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("form_submission_answers")
}

// ═══════════════════════════════════════════════════════════════
// ADDON: STAFF — Gestión de Equipo
// ═══════════════════════════════════════════════════════════════

model StaffConfig {
  id               String   @id @default(cuid())
  guildId          String   @unique
  logChannelId     String?
  alertChannelId   String?
  panelChannelId   String?
  panelMessageId   String?
  inactivityDays   Int      @default(7)
  alertsEnabled    Boolean  @default(true)
  trackVoice       Boolean  @default(true)

  guild            Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  members          StaffMember[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("staff_configs")
}

model StaffMember {
  id           String    @id @default(cuid())
  guildId      String
  userId       String
  configId     String
  roleId       String
  roleName     String
  department   String    @default("general")
  status       String    @default("ACTIVE")
  notes        String?
  lastActiveAt DateTime?
  joinedAt     DateTime  @default(now())

  config       StaffConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
  guild        Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  activities   StaffActivity[]
  sessions     StaffSession[]

  @@unique([guildId, userId])
  @@index([guildId])
  @@map("staff_members")
}

model StaffActivity {
  id        String   @id @default(cuid())
  guildId   String
  memberId  String
  type      String
  detail    String?
  actorId   String?
  timestamp DateTime @default(now())

  member    StaffMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([memberId])
  @@index([timestamp])
  @@map("staff_activities")
}

model StaffSession {
  id              String    @id @default(cuid())
  guildId         String
  memberId        String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationMinutes Int?

  member          StaffMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([memberId])
  @@index([startedAt])
  @@map("staff_sessions")
}


// ─── Links Addon ──────────────────────────────────────────────────────────────

model LinkConfig {
  id                   String   @id @default(cuid())
  guildId              String   @unique
  domain               String   @default("link.korex.dev")
  logChannelId         String?
  notifyHighTraffic    Boolean  @default(true)
  highTrafficThreshold Int      @default(100)
  requireApproval      Boolean  @default(false)
  moderatorRoles       String[] @default([])
  allowedRoles         String[] @default([])
  linksPerUser         Int      @default(50)
  linksPerDay          Int      @default(20)
  defaultExpireDays    Int?
  qrEnabled            Boolean  @default(true)
  qrSize               Int      @default(200)
  websiteName          String?
  logoUrl              String?
  faviconUrl           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  guild      Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  shortLinks ShortLink[]

  @@map("link_configs")
}

model ShortLink {
  id          String    @id @default(cuid())
  guildId     String
  createdBy   String
  slug        String
  destination String
  title       String?
  description String?
  password    String?
  expiresAt   DateTime?
  maxClicks   Int?
  active      Boolean   @default(true)
  approved    Boolean   @default(true)
  totalClicks Int       @default(0)
  uniqueClicks Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  config LinkConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  clicks LinkClick[]

  @@unique([guildId, slug])
  @@index([guildId])
  @@index([createdBy])
  @@index([slug])
  @@map("short_links")
}

model LinkClick {
  id        String   @id @default(cuid())
  linkId    String
  guildId   String
  ip        String?
  country   String?
  city      String?
  device    String?
  browser   String?
  os        String?
  referrer  String?
  userAgent String?
  clickedAt DateTime @default(now())

  link ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([guildId])
  @@index([clickedAt])
  @@map("link_clicks")
}
