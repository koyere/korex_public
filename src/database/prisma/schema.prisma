  userId    String
  username  String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@map("event_rsvps")
}

model EventWaitlist {
  id        String   @id @default(cuid())
