  username     String
  optionIndexes Int[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([pollId, userId])
  @@map("availability_votes")
}

// ─── AI Assistant Addon ───────────────────────────────────────────────────────

model AiAssistantConfig {
  id      String @id @default(cuid())
  guildId String @unique

  // Provider
  aiProvider        String  @default("deepseek")
  aiModel           String  @default("deepseek-chat")
  aiBaseUrl         String?
  aiApiKeyEncrypted String?

  // Chatbot
  chatbotEnabled       Boolean  @default(false)
  chatbotName          String   @default("KorexAI")
  chatbotPersonality   String   @default("helpful")
  chatbotChannels      String[] @default([])
  chatbotTriggerWords  String[] @default([])
  chatbotIgnoreBots    Boolean  @default(true)
  chatbotContextMsgs   Int      @default(5)

  // Auto-moderation
  autoModEnabled          Boolean  @default(false)
  autoModLogChannelId     String?
  autoModWhitelistRoles   String[] @default([])
  autoModWhitelistChannels String[] @default([])
  toxicityEnabled         Boolean  @default(true)
  toxicityThreshold       Float    @default(0.7)
  toxicityAction          String   @default("warn")
  toxicityDuration        Int      @default(3600)
  spamEnabled             Boolean  @default(true)
  spamThreshold           Float    @default(0.8)
  spamAction              String   @default("delete")
  harassmentEnabled       Boolean  @default(true)
  harassmentThreshold     Float    @default(0.9)
  harassmentAction        String   @default("mute")
  harassmentDuration      Int      @default(7200)
  hateEnabled             Boolean  @default(true)
  hateThreshold           Float    @default(0.9)
  hateAction              String   @default("ban")

  // Sentiment analysis
  sentimentEnabled        Boolean  @default(false)
  sentimentChannels       String[] @default([])
  sentimentAlertChannelId String?
  sentimentNegThreshold   Float    @default(-0.5)
  sentimentAlertCooldown  Int      @default(3600)

  // Summaries
  summaryEnabled        Boolean  @default(false)
  summaryChannels       String[] @default([])
  summaryAutoEnabled    Boolean  @default(false)
  summaryAutoMsgCount   Int      @default(100)

  // Translation
  translateEnabled      Boolean  @default(false)
  translateEmoji        String   @default("🌐")
  translateChannels     String[] @default([])
  translateTargetLang   String   @default("es")

  // Rate limits (customizable per guild)
  limitGuildReqDay      Int @default(500)
  limitGuildTokensDay   Int @default(50000)
  limitUserReqDay       Int @default(20)
  limitUserReqHour      Int @default(5)
  limitCooldownSec      Int @default(10)
  limitMaxContext       Int @default(5)
  limitMaxRespTokens    Int @default(500)
  limitConcurrent       Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild              Guild                  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  faqCategories      AiFaqCategory[]
  usageLogs          AiUsageLog[]
  moderationActions  AiModerationAction[]
  sentimentSnapshots AiSentimentSnapshot[]
  conversationContexts AiConversationContext[]

  @@map("ai_assistant_configs")
}

model AiFaqCategory {
  id          String  @id @default(cuid())
  guildId     String
  name        String
  description String?
  enabled     Boolean @default(true)
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config  AiAssistantConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
