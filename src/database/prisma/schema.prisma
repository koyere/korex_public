// ─── Events Addon ─────────────────────────────────────────────────────────────

model EventConfig {
  id                  String   @id @default(cuid())
  guildId             String   @unique
  guild               Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled             Boolean  @default(true)
  defaultChannelId    String?
  announceChannelId   String?
  announceMessageId   String?
  logChannelId        String?
  organizerRoles      String[] @default([])
  rsvpRole            String?
  reminderTimes       Int[]    @default([3600, 1800, 900])
  maxAttendeesDefault Int?
  waitlistTimeout     Int      @default(1800)
  googleCalendarId    String?
  googleAccessToken   String?
  googleRefreshToken  String?
  googleWebhookId     String?
  googleSyncToken     String?
  outlookCalendarId   String?
  outlookAccessToken  String?
  outlookRefreshToken String?
  outlookSubscriptionId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("event_configs")
}

model Event {
  id              String    @id @default(cuid())
  guildId         String
  guild           Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  createdBy       String
  title           String
  description     String?
  location        String?
  meetingUrl      String?
  meetingProvider String?
  startsAt        DateTime
  endsAt          DateTime?
  timezone        String    @default("UTC")
  maxAttendees    Int?
  channelId       String
  messageId       String?
  status          String    @default("SCHEDULED")
  recurrence      String?
  recurrenceEnd   DateTime?
  parentEventId   String?
  googleEventId   String?
  outlookEventId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rsvps        EventRsvp[]
  waitlist     EventWaitlist[]
  reminders    EventReminder[]
  availability AvailabilityPoll[]

  @@index([guildId, startsAt])
  @@index([guildId, status])
  @@map("events")
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
