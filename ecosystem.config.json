{
  "apps": [
    {
      "name": "korex-bot",
      "script": "dist/index.js",
      "cwd": "/home/ubuntu/Korex_Bot_UP",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production"
      },
      "out_file": "/home/ubuntu/Korex_Bot_UP/logs/korex-bot-out.log",
      "error_file": "/home/ubuntu/Korex_Bot_UP/logs/korex-bot-error.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "restart_delay": 5000,
      "max_restarts": 10,
      "min_uptime": "30s",
      "max_memory_restart": "1G",
      "node_args": "--max-old-space-size=2048",
      "autorestart": true,
      "watch": false,
      "ignore_watch": [
        "node_modules",
        "logs",
        "dist",
        "backups",
        ".git"
      ],
      "kill_timeout": 10000,
      "exp_backoff_restart_delay": 1000,
      "env_production": {
        "NODE_ENV": "production"
      },
      "env_development": {
        "NODE_ENV": "development"
      }
    }
  ]
}
