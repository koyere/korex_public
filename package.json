{
  "name": "korex",
  "version": "1.0.0",
  "description": "Bot de Discord profesional auto-alojado - The Core of Your Community",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "start:sharding": "NODE_ENV=production ENABLE_SHARDING=true node dist/sharding/ShardingManager.js",
    "lint": "eslint src --ext .ts",
    "lint:strict": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "db:generate": "prisma generate --schema=src/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=src/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/database/prisma/schema.prisma",
    "db:seed": "tsx src/database/prisma/seed.ts",
    "db:optimize": "tsx scripts/optimize-database.ts",
    "backup:create": "tsx scripts/create-backup.ts",
    "backup:restore": "tsx scripts/restore-backup.ts",
    "health:check": "tsx scripts/health-check.ts",
    "quality:ci": "npm run typecheck && npm run build && npm test -- --runInBand && npm run lint",
    "quality:strict": "npm run typecheck && npm run build && npm test -- --runInBand && npm run lint:strict",
    "deploy:prepare": "npm run build && npm run db:generate && npm run db:optimize",
    "deploy:production": "npm run deploy:prepare && npm run start:production"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript",
    "self-hosted",
    "modular"
  ],
  "author": "Korex Team",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "@prisma/client": "^5.7.1",
    "@simplewebauthn/server": "^13.3.0",
    "@snazzah/davey": "^0.1.11",
    "@types/figlet": "^1.7.0",
    "argon2": "^0.44.0",
    "bcrypt": "^5.1.1",
    "canvas": "^3.2.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.16.1",
    "dotenv": "^16.3.1",
    "erela.js": "^2.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "figlet": "^1.9.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "kazagumo": "^3.4.0",
    "lavalink-client": "^2.7.8",
    "mediaplex": "^1.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "otplib": "^13.4.0",
    "prisma": "^5.7.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "resend": "^6.10.0",
    "socket.io": "^4.7.4",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "youtube-dl-exec": "^3.1.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@simplewebauthn/types": "^12.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.27",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
